#!/bin/sh
# qmodem-esim-bot — Telegram bot for eSIM management on OpenWrt
# POSIX shell (ash/busybox compatible), inspired by 0xygen-AIO bot UI
# Requires: curl, jq, lpac-esim, esim_ctrl.sh
#
# Features:
#   - Inline keyboard buttons with profile switch/delete
#   - Main menu with persistent keyboard
#   - Callback query handling (tap buttons → instant action)
#   - Confirmation before disruptive operations
#   - Settings menu with toggle buttons
#   - EID info with emoji formatting
#   - Download eSIM via LPA string
#   - Process Notifications from button
#   - Status file for LuCI real-time display
#   - 64-bit chat ID handling (ARM 32-bit safe via string compare)

APP_NAME="qmodem-esim-bot"
APP_VER="2.0.0"

###############################################################################
# Configuration
###############################################################################

BOT_TOKEN=""
CHAT_ID=""
POLL_INTERVAL=2
POLL_TIMEOUT=25
ALLOW_DISRUPTIVE=1
REQUIRE_CONFIRM=1
ENABLED=0
DEBUG=0

# Runtime
LAST_UPDATE_ID=0
STATE_DIR="/tmp/lpac-esim"
OFFSET_FILE="$STATE_DIR/telegram.offset"
STATUS_FILE="$STATE_DIR/telegram.status"
PENDING_FILE="$STATE_DIR/telegram.pending"
PID_FILE="/var/run/$APP_NAME.pid"

###############################################################################
# Logging & Helpers
###############################################################################

log_msg() { logger -t "$APP_NAME" "$1"; }
log_debug() { [ "$DEBUG" = "1" ] && logger -t "$APP_NAME" "[D] $1"; }

write_status() {
    local state="$1" rc="$2"
    mkdir -p "$STATE_DIR"
    printf '{"state":"%s","last_poll":%d,"last_rc":%d,"pid":%d}\n' \
        "$state" "$(date +%s)" "${rc:-0}" "$$" > "$STATUS_FILE"
}

save_offset() { echo "$LAST_UPDATE_ID" > "$OFFSET_FILE"; }
load_offset() { [ -f "$OFFSET_FILE" ] && LAST_UPDATE_ID=$(cat "$OFFSET_FILE"); }

save_pending() {
    local action="$1" arg="$2"
    printf '%s\n%s\n' "$action" "$arg" > "$PENDING_FILE"
}

load_pending() {
    [ -f "$PENDING_FILE" ] || return 1
    PEND_ACTION=$(sed -n '1p' "$PENDING_FILE")
    PEND_ARG=$(sed -n '2p' "$PENDING_FILE")
    [ -n "$PEND_ACTION" ]
}

clear_pending() { rm -f "$PENDING_FILE"; }

###############################################################################
# UCI Config
###############################################################################

load_config() {
    . /lib/functions.sh
    config_load qmodem_esim_bot
    config_get ENABLED main enabled "0"
    config_get BOT_TOKEN main token ""
    config_get CHAT_ID main chat_id ""
    config_get POLL_INTERVAL main poll_interval "2"
    config_get ALLOW_DISRUPTIVE main allow_disruptive "1"
    config_get REQUIRE_CONFIRM main require_confirm "1"
    config_get DEBUG main debug "0"

    [ -z "$BOT_TOKEN" ] && { log_msg "ERROR: token not set"; return 1; }
    [ "$ENABLED" != "1" ] && { log_msg "disabled"; return 1; }
    return 0
}

###############################################################################
# Telegram API (64-bit safe: chat_id as string, never arithmetic)
###############################################################################

TG_API=""

tg_post() {
    local method="$1" payload="$2"
    curl -s -m 20 -X POST \
        -H "Content-Type: application/json" \
        -d "$payload" \
        "${TG_API}/${method}" 2>/dev/null
}

# Send message with optional inline keyboard or reply keyboard
tg_send() {
    local text="$1" markup="$2"
    local payload
    payload=$(jq -nc --arg c "$CHAT_ID" --arg t "$text" \
        '{chat_id:$c, text:$t, parse_mode:"HTML"}')
    [ -n "$markup" ] && payload=$(echo "$payload" | jq --argjson m "$markup" '. + {reply_markup:$m}')
    tg_post "sendMessage" "$payload" >/dev/null
}

# Send with inline keyboard JSON string
tg_send_inline() {
    local text="$1" kb_json="$2"
    local payload
    payload=$(jq -nc --arg c "$CHAT_ID" --arg t "$text" --argjson kb "$kb_json" \
        '{chat_id:$c, text:$t, parse_mode:"HTML", reply_markup:{inline_keyboard:$kb}}')
    tg_post "sendMessage" "$payload" >/dev/null
}

# Send with persistent reply keyboard
tg_send_keyboard() {
    local text="$1" kb_json="$2"
    local payload
    payload=$(jq -nc --arg c "$CHAT_ID" --arg t "$text" --argjson kb "$kb_json" \
        '{chat_id:$c, text:$t, parse_mode:"HTML", reply_markup:{keyboard:$kb, resize_keyboard:true}}')
    tg_post "sendMessage" "$payload" >/dev/null
}

tg_answer_cb() {
    local cb_id="$1" text="$2"
    tg_post "answerCallbackQuery" \
        "$(jq -nc --arg id "$cb_id" --arg t "$text" '{callback_query_id:$id, text:$t}')" >/dev/null
}

# Edit an existing message (update in-place)
tg_edit_msg() {
    local msg_id="$1" text="$2" kb_json="$3"
    local payload
    payload=$(jq -nc --arg c "$CHAT_ID" --arg mid "$msg_id" --arg t "$text" \
        '{chat_id:$c, message_id:($mid|tonumber), text:$t, parse_mode:"HTML"}')
    [ -n "$kb_json" ] && payload=$(echo "$payload" | jq --argjson kb "$kb_json" \
        '. + {reply_markup:{inline_keyboard:$kb}}')
    tg_post "editMessageText" "$payload" >/dev/null
}

###############################################################################
# Backend Calls (lpac-esim --api)
###############################################################################

lpac_api() { /usr/bin/lpac-esim --api "$@" 2>/dev/null; }

get_modem_section() {
    uci show qmodem 2>/dev/null | grep "=modem-device" | head -1 | cut -d. -f2 | cut -d= -f1
}

###############################################################################
# UI: Main Menu (persistent keyboard buttons)
###############################################################################

send_main_menu() {
    local kb='[
        [{"text":"📱 Info EID"},{"text":"📋 Profile List"}],
        [{"text":"📥 Download eSIM"},{"text":"🔔 Notifications"}],
        [{"text":"📡 Modem Status"},{"text":"⚙️ Settings"}],
        [{"text":"❓ Help"}]
    ]'
    tg_send_keyboard "<b>QModem eSIM Bot v${APP_VER}</b>

Pilih menu di bawah atau ketik perintah." "$kb"
}

###############################################################################
# UI: EID Info (emoji + storage + profile count)
###############################################################################

send_eid_info() {
    local chip_raw prof_raw
    chip_raw=$(lpac_api chip)
    prof_raw=$(lpac_api profiles)

    local eid svn fw free_nv free_v apps smdp smds prof_count
    eid=$(echo "$chip_raw" | jq -r '.payload.data.eidValue // "-"')
    svn=$(echo "$chip_raw" | jq -r '.payload.data.EUICCInfo2.svn // "-"')
    fw=$(echo "$chip_raw" | jq -r '.payload.data.EUICCInfo2.euiccFirmwareVer // "-"')
    free_nv=$(echo "$chip_raw" | jq -r '.payload.data.EUICCInfo2.extCardResource.freeNonVolatileMemory // "-"')
    free_v=$(echo "$chip_raw" | jq -r '.payload.data.EUICCInfo2.extCardResource.freeVolatileMemory // "-"')
    apps=$(echo "$chip_raw" | jq -r '.payload.data.EUICCInfo2.extCardResource.installedApplication // "0"')
    smdp=$(echo "$chip_raw" | jq -r '.payload.data.EuiccConfiguredAddresses.defaultDpAddress // "Not set"')
    smds=$(echo "$chip_raw" | jq -r '.payload.data.EuiccConfiguredAddresses.rootDsAddress // "-"')
    prof_count=$(echo "$prof_raw" | jq -r '.payload.data | length // 0' 2>/dev/null)
    [ -z "$prof_count" ] && prof_count=0

    # Format memory
    local nv_kb=""
    [ "$free_nv" != "-" ] && nv_kb="$(echo "$free_nv / 1024" | bc 2>/dev/null || echo "$free_nv") KB"
    [ -z "$nv_kb" ] && nv_kb="$free_nv B"

    local text="📱 <b>eUICC / eSIM Chip Info</b>

🔑 <b>EID:</b>
<code>$eid</code>

📊 <b>Chip Info:</b>
  • SVN: <code>$svn</code>
  • Firmware: <code>$fw</code>
  • SM-DP+: <code>$smdp</code>
  • SM-DS: <code>$smds</code>

💾 <b>Storage:</b>
  • Free NV: $nv_kb
  • Free RAM: $free_v B
  • Apps: $apps

📂 <b>Profiles:</b> $prof_count tersimpan"

    tg_send_inline "$text" '[[{"text":"📋 Profile List","callback_data":"menu:profiles"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
}

###############################################################################
# UI: Profile List (inline buttons: active=blue/locked, inactive=red/switch)
###############################################################################

send_profile_list() {
    local raw
    raw=$(lpac_api profiles)
    local count
    count=$(echo "$raw" | jq -r '.payload.data | length' 2>/dev/null)
    [ -z "$count" ] || [ "$count" = "null" ] && count=0

    if [ "$count" = "0" ]; then
        tg_send_inline "📋 <b>Profile List</b>

Tidak ada eSIM profile tersimpan." \
            '[[{"text":"📥 Download eSIM","callback_data":"menu:download"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
        return
    fi

    # Build message text and keyboard JSON
    local text="📋 <b>Profile List eSIM</b> ($count profil)

🔵 = Aktif (locked)
🔴 = Tidak aktif (tap untuk switch)
"
    local kb_rows="" i=0 active_iccid="" inactive_row=""

    while [ $i -lt "$count" ]; do
        local state name iccid provider
        state=$(echo "$raw" | jq -r ".payload.data[$i].profileState")
        name=$(echo "$raw" | jq -r ".payload.data[$i].profileNickname // .payload.data[$i].profileName // \"Profile $((i+1))\"")
        iccid=$(echo "$raw" | jq -r ".payload.data[$i].iccid")
        provider=$(echo "$raw" | jq -r ".payload.data[$i].serviceProviderName // \"-\"")

        if [ "$state" = "enabled" ]; then
            active_iccid="$iccid"
            text="${text}
✅ <b>$name</b> ($provider)
    <code>$iccid</code>"
            # Active profile: full-width row (blue/locked)
            kb_rows="${kb_rows}[{\"text\":\"✅ $name 🔒\",\"callback_data\":\"noop\"}],"
        else
            text="${text}
⬜ $name ($provider)
    <code>$iccid</code>"
            # Inactive: collect 2 per row
            if [ -z "$inactive_row" ]; then
                inactive_row="{\"text\":\"🔴 $name\",\"callback_data\":\"sw:$iccid\"}"
            else
                kb_rows="${kb_rows}[$inactive_row,{\"text\":\"🔴 $name\",\"callback_data\":\"sw:$iccid\"}],"
                inactive_row=""
            fi
        fi
        i=$((i + 1))
    done
    # Flush remaining single inactive button
    [ -n "$inactive_row" ] && kb_rows="${kb_rows}[$inactive_row],"

    # Add action buttons at bottom
    kb_rows="${kb_rows}[{\"text\":\"⚡ Manage Profile\",\"callback_data\":\"menu:manage\"},{\"text\":\"📥 Download\",\"callback_data\":\"menu:download\"}],"
    kb_rows="${kb_rows}[{\"text\":\"🔔 Process Notif\",\"callback_data\":\"act:notifprocess\"},{\"text\":\"🏠 Menu\",\"callback_data\":\"menu:main\"}]"

    local kb="[${kb_rows}]"
    tg_send_inline "$text" "$kb"
}

###############################################################################
# UI: Modem Status
###############################################################################

send_modem_status() {
    local raw
    raw=$(lpac_api modem-status)
    local model op tech sig state
    model=$(echo "$raw" | jq -r '.payload.data.model // "-"')
    op=$(echo "$raw" | jq -r '.payload.data.operator // "-"')
    tech=$(echo "$raw" | jq -r '.payload.data.access_tech // "-"')
    sig=$(echo "$raw" | jq -r '.payload.data.signal_quality // "-"')
    state=$(echo "$raw" | jq -r '.payload.data.state // "-"')

    tg_send_inline "📡 <b>Modem Status</b>

Model: <code>$model</code>
Operator: <b>$op</b>
Technology: $tech
Signal: $sig
State: $state" \
        '[[{"text":"🔄 Refresh","callback_data":"act:status"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
}

###############################################################################
# UI: Settings (toggle buttons for backend config)
###############################################################################

send_settings() {
    local backend proxy skip_slot debug_on
    backend=$(uci -q get lpac-esim.main.apdu_backend || echo "mbim")
    proxy=$(uci -q get lpac-esim.main.mbim_proxy || echo "1")
    skip_slot=$(uci -q get lpac-esim.main.skip_slot_mapping || echo "1")
    debug_on=$(uci -q get lpac-esim.main.apdu_debug || echo "0")
    local allow_d="$ALLOW_DISRUPTIVE"
    local req_c="$REQUIRE_CONFIRM"

    local p_icon="🔴" s_icon="🔴" d_icon="🔴"
    [ "$proxy" = "1" ] && p_icon="🔵"
    [ "$skip_slot" = "1" ] && s_icon="🔵"
    [ "$debug_on" = "1" ] && d_icon="🔵"

    local text="⚙️ <b>Settings</b>

<b>APDU Backend:</b> <code>$backend</code>
<b>MBIM Proxy:</b> $p_icon $([ "$proxy" = "1" ] && echo ON || echo OFF)
<b>Skip Slot Mapping:</b> $s_icon $([ "$skip_slot" = "1" ] && echo ON || echo OFF)
<b>Debug:</b> $d_icon $([ "$debug_on" = "1" ] && echo ON || echo OFF)
<b>Allow Disruptive:</b> $([ "$allow_d" = "1" ] && echo "✅ Yes" || echo "❌ No")
<b>Require Confirm:</b> $([ "$req_c" = "1" ] && echo "✅ Yes" || echo "❌ No")

Tap tombol untuk toggle/ubah:"

    local kb='[
        [{"text":"Backend: QMI","callback_data":"cfg:backend:qmi"},{"text":"Backend: MBIM","callback_data":"cfg:backend:mbim"},{"text":"Backend: AT","callback_data":"cfg:backend:at"}],
        [{"text":"'"$p_icon"' MBIM Proxy","callback_data":"cfg:toggle:mbim_proxy"},{"text":"'"$s_icon"' Skip Slot","callback_data":"cfg:toggle:skip_slot_mapping"}],
        [{"text":"'"$d_icon"' Debug","callback_data":"cfg:toggle:apdu_debug"}],
        [{"text":"🏠 Menu","callback_data":"menu:main"}]
    ]'
    tg_send_inline "$text" "$kb"
}

###############################################################################
# UI: Download eSIM prompt
###############################################################################

send_download_prompt() {
    clear_pending
    save_pending "download" ""
    tg_send_inline "📥 <b>Download eSIM</b>

Kirim activation code format:
<code>LPA:1\$smdp.example.com\$MATCHING-ID</code>

Atau tap Batal." \
        '[[{"text":"❌ Batal","callback_data":"cancel"}]]'
}

###############################################################################
# UI: Notifications
###############################################################################

send_notif_list() {
    local raw
    raw=$(lpac_api notif-list)
    local code
    code=$(echo "$raw" | jq -r '.payload.code // 99')
    if [ "$code" = "0" ]; then
        local count
        count=$(echo "$raw" | jq -r '.payload.data | length // 0' 2>/dev/null)
        [ -z "$count" ] && count=0
        tg_send_inline "🔔 <b>Notifications</b>

Pending: $count notifikasi" \
            '[[{"text":"⚡ Process All","callback_data":"act:notifprocess"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    else
        tg_send_inline "❌ Gagal baca notifikasi." '[[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    fi
}

###############################################################################
# UI: Manage Profile (delete buttons, active locked out)
###############################################################################

send_manage_menu() {
    local raw
    raw=$(lpac_api profiles)
    local count
    count=$(echo "$raw" | jq -r '.payload.data | length' 2>/dev/null)
    [ -z "$count" ] || [ "$count" = "null" ] && count=0

    if [ "$count" = "0" ]; then
        tg_send_inline "🗑 <b>Manage Profile</b>

Tidak ada profile." '[[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
        return
    fi

    local text="🗑 <b>Manage Profile</b>

⚠️ Profile <b>ACTIVE</b> dikunci (tidak bisa dihapus).
Tap tombol 🗑 untuk hapus profile disabled.
"
    local kb_rows="" i=0 has_disabled=0

    while [ $i -lt "$count" ]; do
        local state name iccid
        state=$(echo "$raw" | jq -r ".payload.data[$i].profileState")
        name=$(echo "$raw" | jq -r ".payload.data[$i].profileNickname // .payload.data[$i].profileName // \"Profile $((i+1))\"")
        iccid=$(echo "$raw" | jq -r ".payload.data[$i].iccid")

        if [ "$state" = "enabled" ]; then
            text="${text}
🔵 <b>$name</b> 🔒"
        else
            text="${text}
🔴 $name"
            kb_rows="${kb_rows}[{\"text\":\"🗑 $name\",\"callback_data\":\"del:$iccid\"}],"
            has_disabled=1
        fi
        i=$((i + 1))
    done

    if [ "$has_disabled" = "0" ]; then
        kb_rows='[{"text":"Tidak ada profile disabled","callback_data":"noop"}],'
    fi

    kb_rows="${kb_rows}[{\"text\":\"📋 Profile List\",\"callback_data\":\"menu:profiles\"},{\"text\":\"🏠 Menu\",\"callback_data\":\"menu:main\"}]"
    tg_send_inline "$text" "[${kb_rows}]"
}

###############################################################################
# Lock Polling (wait for async backend operation to finish)
###############################################################################

poll_lock_result() {
    local timeout="${1:-120}"
    local elapsed=0
    while [ $elapsed -lt "$timeout" ]; do
        sleep 5
        elapsed=$((elapsed + 5))
        local lock_raw
        lock_raw=$(lpac_api lock-status)
        local locked
        locked=$(echo "$lock_raw" | jq -r '.payload.data.locked // false')
        if [ "$locked" != "true" ]; then
            # Operation finished — return the last_result if available
            echo "$lock_raw" | jq -r '.payload.data.last_result // empty' 2>/dev/null
            return 0
        fi
    done
    return 124  # timeout
}

###############################################################################
# Actions (disruptive operations with confirmation)
###############################################################################

do_switch() {
    local iccid="$1"
    tg_send "⏳ <b>Switching profile...</b>
Mohon tunggu 30-60 detik..."
    local section result status
    section=$(get_modem_section)
    if [ -n "$section" ]; then
        result=$(/usr/share/qmodem/esim_ctrl.sh profile_enable "$section" "{\"iccid\":\"$iccid\",\"refresh\":\"0\"}")
    else
        result='{"result":{"status":"0","error":"no modem section"}}'
    fi
    status=$(echo "$result" | jq -r '.result.status // "0"')
    if [ "$status" = "1" ]; then
        tg_send_inline "✅ <b>Profile Switched</b>

ICCID: <code>$iccid</code>
Internet dipulihkan." \
            '[[{"text":"📋 Profile List","callback_data":"menu:profiles"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    else
        local err
        err=$(echo "$result" | jq -r '.result.error // "Unknown"')
        tg_send_inline "❌ <b>Switch Gagal</b>

Error: $err" \
            '[[{"text":"📋 Profile List","callback_data":"menu:profiles"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    fi
}

do_delete() {
    local iccid="$1"
    tg_send "⏳ Menghapus profile..."
    local section result status
    section=$(get_modem_section)
    if [ -n "$section" ]; then
        result=$(/usr/share/qmodem/esim_ctrl.sh profile_delete "$section" "{\"iccid\":\"$iccid\"}")
    else
        result='{"result":{"status":"0","error":"no modem section"}}'
    fi
    status=$(echo "$result" | jq -r '.result.status // "0"')
    if [ "$status" = "1" ]; then
        tg_send_inline "✅ Profile dihapus." \
            '[[{"text":"📋 Profile List","callback_data":"menu:profiles"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    else
        local err
        err=$(echo "$result" | jq -r '.result.error // "Unknown"')
        tg_send_inline "❌ Gagal hapus: $err" \
            '[[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    fi
}

do_download() {
    local lpa="$1"
    tg_send "⏳ <b>Downloading profile...</b>
Mohon tunggu..."
    local result code msg
    result=$(lpac_api download --lpa "$lpa")
    code=$(echo "$result" | jq -r '.payload.code // 99')
    msg=$(echo "$result" | jq -r '.payload.message // ""')

    # Check if backend returned "processing" (async operation)
    if [ "$msg" = "processing" ]; then
        tg_send "⏳ Download sedang diproses backend...
Menunggu hasil (max 3 menit)..."
        local lock_result
        lock_result=$(poll_lock_result 180)
        if [ $? -eq 0 ] && [ -n "$lock_result" ]; then
            local success
            success=$(echo "$lock_result" | jq -r '.success // true' 2>/dev/null)
            if [ "$success" = "false" ]; then
                tg_send_inline "❌ <b>Download Gagal</b>

$(echo "$lock_result" | jq -r '.message // "Unknown error"' 2>/dev/null)" \
                    '[[{"text":"📥 Coba Lagi","callback_data":"menu:download"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
            else
                tg_send_inline "✅ <b>Profile Downloaded</b>

Gunakan Profile List untuk melihat dan switch.
Jalankan Process Notifications jika profile belum aktif." \
                    '[[{"text":"📋 Profile List","callback_data":"menu:profiles"},{"text":"🔔 Process Notif","callback_data":"act:notifprocess"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
            fi
        else
            tg_send_inline "⚠️ <b>Download masih diproses</b>

Backend belum selesai setelah 3 menit.
Cek Profile List untuk status terbaru." \
                '[[{"text":"📋 Profile List","callback_data":"menu:profiles"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
        fi
        return
    fi

    if [ "$code" = "0" ]; then
        tg_send_inline "✅ <b>Profile Downloaded</b>

Gunakan Profile List untuk melihat dan switch." \
            '[[{"text":"📋 Profile List","callback_data":"menu:profiles"},{"text":"🔔 Process Notif","callback_data":"act:notifprocess"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    else
        [ -z "$msg" ] && msg="Unknown error"
        tg_send_inline "❌ <b>Download Gagal</b>

Error: $msg" \
            '[[{"text":"📥 Coba Lagi","callback_data":"menu:download"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    fi
}

do_notif_process() {
    tg_send "⏳ Memproses notifikasi..."
    local result code
    result=$(lpac_api notif-process)
    code=$(echo "$result" | jq -r '.payload.code // 99')
    if [ "$code" = "0" ]; then
        tg_send_inline "✅ Notifikasi diproses." \
            '[[{"text":"📋 Profile List","callback_data":"menu:profiles"}],[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    else
        tg_send_inline "❌ Gagal proses notifikasi." \
            '[[{"text":"🏠 Menu","callback_data":"menu:main"}]]'
    fi
}

###############################################################################
# Callback Query Handler (inline keyboard button taps)
###############################################################################

handle_callback() {
    local cb_id="$1" data="$2" cb_chat="$3"

    # Security: only respond to authorized chat (string compare, 64-bit safe)
    [ -n "$CHAT_ID" ] && [ "$cb_chat" != "$CHAT_ID" ] && return

    case "$data" in
        # Navigation
        menu:main)      tg_answer_cb "$cb_id" "Menu"; clear_pending; send_main_menu ;;
        menu:profiles)  tg_answer_cb "$cb_id" "Loading profiles..."; send_profile_list ;;
        menu:manage)    tg_answer_cb "$cb_id" "Manage profiles"; send_manage_menu ;;
        menu:download)  tg_answer_cb "$cb_id" "Download"; send_download_prompt ;;
        menu:notif)     tg_answer_cb "$cb_id" "Notifications"; send_notif_list ;;
        menu:settings)  tg_answer_cb "$cb_id" "Settings"; send_settings ;;
        noop)           tg_answer_cb "$cb_id" "Profile aktif (locked)" ;; # locked button

        # Actions
        act:status)     tg_answer_cb "$cb_id" "Refreshing..."; send_modem_status ;;
        act:notifprocess) tg_answer_cb "$cb_id" "Processing..."; do_notif_process ;;

        # Profile switch (ask confirmation)
        sw:*)
            local iccid="${data#sw:}"
            tg_answer_cb "$cb_id" "Switch profile..."
            if [ "$ALLOW_DISRUPTIVE" != "1" ]; then
                tg_send "⛔ Operasi disruptive dinonaktifkan."
                return
            fi
            if [ "$REQUIRE_CONFIRM" = "1" ]; then
                save_pending "switch" "$iccid"
                tg_send_inline "⚠️ <b>Konfirmasi Switch Profile</b>

ICCID: <code>$iccid</code>

Internet akan TERPUTUS 30-60 detik.
Lanjutkan?" \
                    '[[{"text":"✅ Ya, Switch","callback_data":"confirm:yes"},{"text":"❌ Batal","callback_data":"cancel"}]]'
            else
                do_switch "$iccid"
            fi
            ;;

        # Profile delete (ask confirmation)
        del:*)
            local iccid="${data#del:}"
            tg_answer_cb "$cb_id" "Delete profile..."
            if [ "$ALLOW_DISRUPTIVE" != "1" ]; then
                tg_send "⛔ Operasi disruptive dinonaktifkan."
                return
            fi
            save_pending "delete" "$iccid"
            tg_send_inline "🗑 <b>Konfirmasi Hapus Profile</b>

ICCID: <code>$iccid</code>

⚠️ Profile dihapus permanen!
Lanjutkan?" \
                '[[{"text":"🗑 Ya, Hapus","callback_data":"confirm:yes"},{"text":"❌ Batal","callback_data":"cancel"}]]'
            ;;

        # Confirmation
        confirm:yes)
            tg_answer_cb "$cb_id" "Executing..."
            if load_pending; then
                case "$PEND_ACTION" in
                    switch)   do_switch "$PEND_ARG" ;;
                    delete)   do_delete "$PEND_ARG" ;;
                    download) do_download "$PEND_ARG" ;;
                esac
                clear_pending
            else
                tg_send "⚠️ Tidak ada operasi pending."
            fi
            ;;

        cancel)
            tg_answer_cb "$cb_id" "Dibatalkan"
            clear_pending
            tg_send_inline "❌ Dibatalkan." \
                '[[{"text":"📋 Profile List","callback_data":"menu:profiles"},{"text":"🏠 Menu","callback_data":"menu:main"}]]'
            ;;

        # Settings toggles
        cfg:backend:*)
            local be="${data#cfg:backend:}"
            tg_answer_cb "$cb_id" "Backend: $be"
            uci -q set lpac-esim.main.apdu_backend="$be"
            uci -q commit lpac-esim
            send_settings
            ;;
        cfg:toggle:*)
            local key="${data#cfg:toggle:}"
            local cur=$(uci -q get "lpac-esim.main.$key" || echo "0")
            local new=$([ "$cur" = "1" ] && echo "0" || echo "1")
            tg_answer_cb "$cb_id" "$key: $([ "$new" = "1" ] && echo ON || echo OFF)"
            uci -q set "lpac-esim.main.$key=$new"
            uci -q commit lpac-esim
            send_settings
            ;;
    esac
}

###############################################################################
# Text Message Handler
###############################################################################

handle_message() {
    local chat="$1" text="$2"

    # Security: string compare (64-bit safe on 32-bit ARM)
    [ -n "$CHAT_ID" ] && [ "$chat" != "$CHAT_ID" ] && {
        # Only respond to /chatid for unauthorized users
        case "$text" in /chatid|/start)
            local payload
            payload=$(jq -nc --arg c "$chat" --arg t "Your Chat ID: $chat" \
                '{chat_id:$c, text:$t}')
            tg_post "sendMessage" "$payload" >/dev/null
        esac
        return
    }

    # Check if we're waiting for input (download LPA string)
    if load_pending && [ "$PEND_ACTION" = "download" ] && [ -z "$PEND_ARG" ]; then
        case "$text" in
            LPA:1\$*|lpa:1\$*)
                save_pending "download" "$text"
                tg_send_inline "📥 <b>Konfirmasi Download</b>

<code>$text</code>

Lanjutkan download?" \
                    '[[{"text":"✅ Ya, Download","callback_data":"confirm:yes"},{"text":"❌ Batal","callback_data":"cancel"}]]'
                ;;
            *)
                tg_send "⚠️ Format harus: <code>LPA:1\$server\$matchingId</code>

Atau tap Batal."
                ;;
        esac
        return
    fi

    # Parse command
    local cmd arg
    cmd=$(echo "$text" | awk '{print $1}')
    arg=$(echo "$text" | cut -d' ' -f2- -s)

    case "$cmd" in
        # Slash commands
        /start|/menu)       send_main_menu ;;
        /help)              tg_send "📋 <b>Commands</b>

/eid - Info eUICC
/profiles - Daftar profile
/status - Status modem
/download &lt;LPA&gt; - Download profile
/enable &lt;ICCID&gt; - Switch profile
/delete &lt;ICCID&gt; - Hapus profile
/notif - Proses notifikasi
/settings - Pengaturan
/chatid - Tampilkan Chat ID" ;;
        /chatid)            tg_send "Chat ID: <code>$chat</code>" ;;
        /eid|/info)         send_eid_info ;;
        /profiles|/profile) send_profile_list ;;
        /status)            send_modem_status ;;
        /settings)          send_settings ;;
        /notif)             do_notif_process ;;
        /download)
            if [ -n "$arg" ]; then
                case "$arg" in LPA:1\$*|lpa:1\$*)
                    save_pending "download" "$arg"
                    tg_send_inline "📥 Konfirmasi download:
<code>$arg</code>" \
                        '[[{"text":"✅ Download","callback_data":"confirm:yes"},{"text":"❌ Batal","callback_data":"cancel"}]]'
                    ;; *)
                    tg_send "⚠️ Format: /download LPA:1\$server\$matchingId"
                    ;; esac
            else
                send_download_prompt
            fi ;;
        /enable|/switch)
            [ -z "$arg" ] && { tg_send "⚠️ Format: /enable &lt;ICCID&gt;"; return; }
            if [ "$REQUIRE_CONFIRM" = "1" ]; then
                save_pending "switch" "$arg"
                tg_send_inline "⚠️ Switch ke <code>$arg</code>?" \
                    '[[{"text":"✅ Ya","callback_data":"confirm:yes"},{"text":"❌ Batal","callback_data":"cancel"}]]'
            else
                do_switch "$arg"
            fi ;;
        /delete)
            [ -z "$arg" ] && { tg_send "⚠️ Format: /delete &lt;ICCID&gt;"; return; }
            save_pending "delete" "$arg"
            tg_send_inline "🗑 Hapus <code>$arg</code>?" \
                '[[{"text":"🗑 Ya","callback_data":"confirm:yes"},{"text":"❌ Batal","callback_data":"cancel"}]]'
            ;;

        # Keyboard button text (from persistent menu)
        "📱 Info EID")       send_eid_info ;;
        "📋 Profile List")   send_profile_list ;;
        "📥 Download eSIM")  send_download_prompt ;;
        "🔔 Notifications")  send_notif_list ;;
        "📡 Modem Status")   send_modem_status ;;
        "⚙️ Settings")       send_settings ;;
        "❓ Help")           tg_send "/eid /profiles /status /download /enable /delete /notif /settings" ;;
        "🏠 Menu"|"Menu Utama") send_main_menu ;;

        # Unknown: show menu
        *)  send_main_menu ;;
    esac
}

###############################################################################
# Update Processor
###############################################################################

process_update() {
    local update="$1"

    # Callback query (inline button tap)
    local cb_id cb_data cb_chat
    cb_id=$(echo "$update" | jq -r '.callback_query.id // empty')
    if [ -n "$cb_id" ]; then
        cb_data=$(echo "$update" | jq -r '.callback_query.data // empty')
        cb_chat=$(echo "$update" | jq -r '.callback_query.message.chat.id | tostring')
        handle_callback "$cb_id" "$cb_data" "$cb_chat"
        return
    fi

    # Text message
    local msg_chat msg_text
    msg_chat=$(echo "$update" | jq -r '.message.chat.id | tostring')
    msg_text=$(echo "$update" | jq -r '.message.text // empty')
    [ -z "$msg_text" ] && return

    handle_message "$msg_chat" "$msg_text"
}

###############################################################################
# Main Loop
###############################################################################

cleanup() {
    save_offset
    write_status "stopped" 0
    rm -f "$PID_FILE"
    log_msg "stopped"
    exit 0
}

main() {
    mkdir -p "$STATE_DIR"
    load_config || exit 1
    TG_API="https://api.telegram.org/bot${BOT_TOKEN}"
    load_offset
    echo $$ > "$PID_FILE"
    trap cleanup INT TERM

    log_msg "Bot started (poll=${POLL_INTERVAL}s, chat_id=${CHAT_ID})"
    write_status "starting" 0

    local consecutive_fail=0

    while true; do
        local offset=$((LAST_UPDATE_ID + 1))
        local response

        response=$(curl -s -m $((POLL_TIMEOUT + 10)) \
            "${TG_API}/getUpdates?offset=${offset}&timeout=${POLL_TIMEOUT}&allowed_updates=%5B%22message%22%2C%22callback_query%22%5D" \
            2>/dev/null)

        if [ -z "$response" ]; then
            consecutive_fail=$((consecutive_fail + 1))
            write_status "error" "$consecutive_fail"
            [ $((consecutive_fail % 10)) -eq 1 ] && log_msg "getUpdates empty (fail=$consecutive_fail)"
            sleep 10
            continue
        fi

        local ok
        ok=$(echo "$response" | jq -r '.ok')
        if [ "$ok" != "true" ]; then
            consecutive_fail=$((consecutive_fail + 1))
            write_status "error" "$consecutive_fail"
            [ $((consecutive_fail % 10)) -eq 1 ] && log_msg "API error: $(echo "$response" | jq -r '.description // "?"')"
            sleep 10
            continue
        fi

        consecutive_fail=0
        write_status "ok" 0

        # Process updates
        local count
        count=$(echo "$response" | jq '.result | length')
        if [ -n "$count" ] && [ "$count" -gt 0 ]; then
            local idx=0
            while [ $idx -lt "$count" ]; do
                local update uid
                update=$(echo "$response" | jq ".result[$idx]")
                uid=$(echo "$update" | jq -r '.update_id')
                [ "$uid" -gt "$LAST_UPDATE_ID" ] && {
                    LAST_UPDATE_ID=$uid
                    process_update "$update"
                }
                idx=$((idx + 1))
            done
            save_offset
        fi

        sleep "$POLL_INTERVAL"
    done
}

main "$@"
