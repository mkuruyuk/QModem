#!/bin/sh /etc/rc.common
# mbim-proxy: standalone procd service for libmbim's MBIM multiplexer.
#
# Purpose:
#   Provides shared access to /dev/cdc-wdm* so multiple consumers
#   (e.g. quectel-CM-M, lpac, mbimcli) can talk to a single MBIM device
#   without holding an exclusive open. This is the same model that
#   ModemManager uses internally with libmbim.
#
# Order:
#   START=70 runs BEFORE qmodem_init (START=80, scans modems) and
#   qmodem_network (START=99, dials). Procd's respawn handles transient
#   crashes; modem_dial.sh just probes `pidof mbim-proxy` to decide
#   whether to pass `-p mbim-proxy` to quectel-CM-M.
#
# Activation:
#   The daemon is started unconditionally when the libmbim binary is
#   present. While idle (no clients) it does NOT open /dev/cdc-wdm*,
#   so it has zero side-effect on non-MBIM/non-eSIM setups. Users who
#   do not want it running can disable the service:
#     /etc/init.d/mbim-proxy disable
#
# Why not gate on qmodem UCI:
#   qmodem config is populated by modem_scan.sh (START=80) which runs
#   AFTER us. Gating here would mean the proxy is missing during the
#   first dial cycle and we would race with quectel-CM-M's exclusive
#   open of the cdc-wdm device. Always-on, idle-when-unused is the
#   safe default.

START=70
STOP=89
USE_PROCD=1

PROXY_BIN=""

find_proxy_bin() {
	for cand in /usr/libexec/mbim-proxy /usr/sbin/mbim-proxy /usr/lib/mbim-proxy /usr/bin/mbim-proxy; do
		if [ -x "$cand" ]; then
			PROXY_BIN="$cand"
			return 0
		fi
	done
	return 1
}

start_service() {
	if ! find_proxy_bin; then
		logger -t mbim-proxy "binary not found, skipping (install libmbim for eSIM coexistence)"
		return 0
	fi

	procd_open_instance "mbim-proxy"
	procd_set_param command "$PROXY_BIN" --no-exit
	# threshold=30s, retries=5, max-wait=0 (infinite). Matches the
	# resilience profile we want: temporary USB unbinds shouldn't
	# tear the unit down permanently.
	procd_set_param respawn 30 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
	logger -t mbim-proxy "started ($PROXY_BIN --no-exit)"
}

reload_service() {
	stop
	sleep 1
	start
}
