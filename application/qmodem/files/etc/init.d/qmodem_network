#!/bin/sh /etc/rc.common
START=99
STOP=13
USE_PROCD=1
service="$(basename ${basescript:-$initscript})"
#脚本目录
SCRIPT_DIR="/usr/share/qmodem"

#运行目录
MODEM_RUNDIR="/var/run/qmodem"

extra_command "dial" "<modem_cfg> run dial script"
extra_command "hang" "<modem_cfg> run hang script"
extra_command "redial" "<modem_cfg> stop previous dial script. run hang script. and run dial script"
extra_command "modem_status" "<modem_cfg> Check dial script status" 
extra_command "start_led_service" "<modem_cfg> add led service for modem"
extra_command "stop_led_service" "<modem_cfg> stop led service for modem"

service_triggers()
{
	procd_add_reload_trigger "qmodem"

}

start_service(){
    force_stop=0
    mkdir -p $MODEM_RUNDIR
    config_load qmodem
    config_get g_enabled main enable_dial
    config_foreach _start_modem_instance modem-device
}

_start_modem_instance()
{
    local cfg="$1"
    config_get enabled "$cfg" enable_dial
    config_get state "$cfg" state
    if [ "$state" = "disabled" ] || [ "$enabled" = "0" ] || [ "$g_enabled" = "0" ]; then
        return
    fi
    procd_open_instance "modem_$cfg"
    procd_set_param command "/usr/share/qmodem/modem_dial.sh" "$cfg" dial
    procd_set_param respawn 120 15 10
    procd_close_instance
    logger -t qmodem_network "Modem $cfg Start Dial Now (start_service)"
}

stop_service(){
    # procd automatically stops all instances when service stops
    # We just need to run hang scripts for cleanup (flush interfaces)
    config_load qmodem
    config_foreach _stop_modem_instance modem-device
}

_stop_modem_instance()
{
    local cfg="$1"
    /usr/share/qmodem/modem_dial.sh "$cfg" hang 2>/dev/null
    logger -t qmodem_network "Modem $cfg stopped (stop_service)"
}

reload_service()
{
    # On reload: stop all, then re-register instances
    stop
    sleep 1
    start
}


dial()
{
    # When called as extra_command (outside start_service context),
    # we need to restart the service to add the new instance properly.
    # This ensures procd 25.x compatibility.
    local cfg="$1"
    config_load qmodem
    config_get state "$cfg" state
    if [ "$state" = "disabled" ]; then
        logger -t qmodem_network "Modem $cfg is disabled, not dialing"
        return
    fi
    # Use procd_open_instance within rc_procd wrapper
    rc_procd _dial "$cfg"
    start_led_service "$cfg"
}

hang()
{
    _hang $1
    stop_led_service $1
}

modem_status()
{
    _modem_status $1
}

redial()
{
    hang $1
    dial $1
}

_dial()
{
    procd_open_instance "modem_$1"
    procd_set_param command "/usr/share/qmodem/modem_dial.sh" "$1" dial
    procd_set_param respawn 120 15 10
    procd_close_instance
    logger -t qmodem_network "Modem $1 Start Dial Now"
}

_hang()
{
    procd_kill $service "modem_$1"
    /usr/share/qmodem/modem_dial.sh "$1" hang
    logger -t qmodem_network "Modem $1 Stop Dial and Hang"
}

_modem_status()
{ 
	local instances="modem_$1"
	local data
    data=$(_procd_ubus_call list | jq  -r ".$service.instances.$instances")
    [ "$data" == "null" ] && echo "$instances Not Running"  || echo "$data"
}

start_led_service()
{
    rc_procd _led_service "$1"
}

_led_service(){
    local led_script
    config_load qmodem
    config_get led_script "$1" led_script
    if [ -n "$led_script" ] && [ -x "/usr/share/qmodem/led_scripts/${led_script}.sh" ]; then
        config_load qmodem
        config_get led_script "$1" led_script
        procd_open_instance led_$1
        procd_set_param command "/usr/share/qmodem/led_scripts/${led_script}.sh" "$1"
        procd_set_param respawn 120 15 10
        procd_close_instance
        logger -t qmodem_network "Start LED service for modem $1 with script $led_script"
    fi
}

stop_led_service(){
    local led_script
    config_load qmodem
    config_get led_script "$1" led_script
    if [ -n "$led_script" ] && [ -x "/usr/share/qmodem/led_scripts/${led_script}.sh" ]; then
        /usr/share/qmodem/led_scripts/${led_script}.sh "$1" "off"
    fi
    # remove led service instance
    procd_kill $service "led_$1"
}
